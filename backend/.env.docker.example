# Docker 部署用 - 複製為 .env.docker 後修改
# 注意：DATABASE_URL host 為 postgres（容器名稱），不是 localhost
DATABASE_URL=postgresql://sa:password@postgres:5432/tally

# PostgreSQL 容器初始化用（與上方保持一致）
POSTGRES_USER=sa
POSTGRES_PASSWORD=password
POSTGRES_DB=tally

JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=production
